    {
      "id": "voice-send-owner-notif",
      "name": "Send Voice Notification",
      "type": "n8n-nodes-base.code",
      "position": [
        1840,
        600
      ],
      "typeVersion": 2,
      "parameters": {
        "jsCode": "const ownerChatId = $('Get Owner Chat ID').first().json.owner_chat_id;\nconst ticket = $('Edit Fields').item.json;\nconst isUrgent = ticket.urgency === 'urgent';\nconst botToken = $env.TELEGRAM_BOT_TOKEN || 'TELEGRAM_BOT_TOKEN_SET_IN_ENV';\n// Is Dion testing? Route to Dion instead of Julia\nconst tenantPhone = $('Edit Fields').item.json.phone || '';\nconst isDion = tenantPhone.includes('5148319058');\nconst chatId = isDion ? '6216258938' : ownerChatId;\n\n\nlet text = '';\nlet replyMarkup = null;\n\nif (isUrgent) {\n  text = '\\u{1F6A8} <b>URGENT TICKET ' + ticket.ticket_id + '</b>\\n\\n'\n    + '<b>Category:</b> ' + (ticket.category || '').replace(/_/g, ' ') + '\\n'\n    + '<b>Tenant:</b> ' + (ticket.tenant_name || '') + '\\n'\n    + '<b>Unit:</b> ' + (ticket.unit_number || '') + '\\n'\n    + '<b>Summary:</b> ' + (ticket.summary || '') + '\\n'\n    + '<b>Channel:</b> Phone';\n  replyMarkup = JSON.stringify({\n    inline_keyboard: [[\n      { text: 'Auto Dispatch', callback_data: 'dispatch||' + ticket.ticket_id + '||' + (ticket.category || '') },\n      { text: 'Show Contractors', callback_data: 'manual||' + ticket.ticket_id + '||' + (ticket.category || '') }\n    ]]\n  });\n} else {\n  text = '\\u{1F4CB} <b>NEW TICKET ' + ticket.ticket_id + '</b>\\n\\n'\n    + '<b>Category:</b> ' + (ticket.category || '').replace(/_/g, ' ') + '\\n'\n    + '<b>Tenant:</b> ' + (ticket.tenant_name || '') + '\\n'\n    + '<b>Unit:</b> ' + (ticket.unit_number || '') + '\\n'\n    + '<b>Summary:</b> ' + (ticket.summary || '') + '\\n'\n    + '<b>Channel:</b> Phone';\n}\n\nconst body = { chat_id: chatId, text, parse_mode: 'HTML' };\nif (replyMarkup) body.reply_markup = replyMarkup;\n\nawait this.helpers.httpRequest({\n  method: 'POST',\n  url: 'https://api.telegram.org/bot' + botToken + '/sendMessage',\n  body,\n  json: true\n});\n\nreturn [{ json: { sent: true, ownerChatId: chatId, ticketId: ticket.ticket_id, isUrgent } }];"
      }
    }
