    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  t.name as tenant_name,\n  t.unit_number,\n  t.phone,\n  p.name as property_name,\n  mr.ticket_id,\n  mr.category,\n  mr.summary,\n  mr.urgency,\n  mr.status,\n  mr.created_at\nFROM tenants t\nLEFT JOIN properties p ON t.property_id = p.id\nLEFT JOIN maintenance_requests mr \n  ON mr.phone = t.phone \n  AND mr.status NOT IN ('closed', 'resolved')\nWHERE t.phone = '{{ $json.body.tenant_phone.replace(/[^0-9]/g, '').replace(/'/g, \"''\") }}'\nORDER BY mr.created_at DESC\nLIMIT 5;",
        "options": {
          "alwaysOutputData": true
        }
      },
