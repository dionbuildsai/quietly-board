        "jsCode": "const body = $json.body || $json;\nconst text = (body.text || '').trim();\nreturn [{ json: {\n  ticket_id: body.ticket_id || '',\n  channel: body.channel || '',\n  chat_id: String(body.chat_id || ''),\n  phone: body.phone || '',\n  email: body.email || '',\n  text: text,\n  response_text: text,\n} }];"
