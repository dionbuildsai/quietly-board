        "query": "INSERT INTO messages (ticket_id, sender, message_text, channel, chat_id, created_at) VALUES ('{{ $json.ticket_id.replace(/'/g, \"''\") }}', 'owner', '{{ $json.text.replace(/'/g, \"''\") }}', '{{ $json.channel }}', '{{ $json.chat_id.replace(/'/g, \"''\") }}', NOW()) ON CONFLICT DO NOTHING",
        "options": {}
