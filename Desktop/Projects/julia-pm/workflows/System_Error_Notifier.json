        "jsCode": "const err = $input.first().json;\nconst wfName = err.workflow?.name || 'unknown workflow';\nconst errMsg = err.execution?.error?.message || err.execution?.lastNodeExecuted || 'unknown error';\nconst execId = err.execution?.id || '';\nconst text = 'n8n ERROR in: ' + wfName + '\\n' +\n  'Error: ' + errMsg + '\\n' +\n  'Exec: https://n8n.srv1285597.hstgr.cloud/workflow/executions/' + execId;\nawait this.helpers.httpRequest({\n  method: 'POST',\n  url: 'https://api.telegram.org/bot8460031715:AAE1IQYICVYo3BfDcOjY4IKYVu0iI4V9lZ8/sendMessage',\n  body: { chat_id: 6216258938, text: text },\n  json: true\n});\nreturn [{ json: { notified: true, workflow: wfName, error: errMsg } }];"
      }
    }
  ],
