    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  COALESCE(t.name, 'there') AS tenant_name,\n  COALESCE(t.unit_number, '') AS unit_number,\n  COALESCE(t.phone, '') AS phone,\n  COALESCE(p.name, '') AS property_name\nFROM (SELECT 1) dummy\nLEFT JOIN tenants t ON t.phone = '{{ $json.clean_phone }}'\nLEFT JOIN properties p ON t.property_id = p.id\nLIMIT 1;",
