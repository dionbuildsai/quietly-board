        "jsCode": "const sql = $input.first().json;\nconst phone = $('Extract Phone').first().json.clean_phone;\nreturn [{\n  json: {\n    type: 'conversation_initiation_client_data',\n    dynamic_variables: {\n      caller_phone: sql.phone || phone,\n      tenant_name: sql.tenant_name || 'there',\n      unit_number: sql.unit_number || '',\n      property_name: sql.property_name || ''\n    }\n  }\n}];"
